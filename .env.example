# PTAB Intelligence — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# AWS
AWS_PROFILE=ptab
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=604881392797

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=ptab-documents
PINECONE_ENVIRONMENT=us-east-1

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# S3
PTAB_DOCS_BUCKET=ptab-documents-604881392797
TF_STATE_BUCKET=ptab-tf-state-604881392797

# Secrets Manager
SECRETS_PREFIX=ptab/

# API Gateway (populated after deploy)
API_GATEWAY_URL=
